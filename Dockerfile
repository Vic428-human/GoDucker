# 你的需求是什麼？
# │
# ├─ 🔧 開發/學習環境
# │  └─ → 用 `golang:1.26-alpine`（最小體積 + 最新功能）
# │
# ├─ 🚀 生產環境 + 追求最小映像
# │  ├─ 應用程式純 Go 無 CGO → `golang:1.26-alpine3.23`
# │  └─ 有 CGO/系統依賴 → 改用 `golang:1.26-bookworm`
# │
# ├─ 🔒 需要長期穩定/企業環境
# │  └─ → 用 `golang:1.25-alpine3.23`（已驗證穩定）+ 明確指定 Alpine 版本
# │
# └─ 📚 跟著舊教學做
#    └─ → 可先用 `1.22-alpine` 跑通，再逐步升級到 1.26
From golang:1.25-alpine

# 設定工作目錄為 /app，設定一次，後續指令都在 /app 下執行
WORKDIR /app

## 第一次 COPY → 只處理依賴，快取效果好。
# 第一次 只把 go.mod 和 go.sum 複製進容器。
# go.mod（依賴清單）
# go.sum（依賴雜湊驗證）
COPY go.* ./ 

# 如果只修改程式碼（.go 檔案）
# go mod download 不會重新執行，節省大量時間。
# 下載依賴
RUN go mod download  

# 上面步驟呈現的效果
# ┌─────────────────────────────────────────────────────────┐
# │  本地專案目錄 (Build Context)                           │
# │  ├── go.mod  ─────────────────────────────┐            │
# │  ├── go.sum  ─────────────────────────────┼─ COPY go.* │
# │  ├── main.go                              │            │
# │  └── handlers/                            │            │
# └───────────────────────────────────────────┼────────────┘
#                                             ▼
# ┌─────────────────────────────────────────────────────────┐
# │  Docker 映像內部 (WORKDIR /app)                         │
# │  ├── go.mod  ✅ (先複製)                                │
# │  ├── go.sum  ✅ (先複製)                                │
# │  ├── (依賴下載完成)                                     │
# │  ├── main.go  ⏳ (後續才複製)                           │
# │  └── handlers/  ⏳ (後續才複製)                         │
# └─────────────────────────────────────────────────────────┘

## 第二次 COPY → 放入程式碼，避免影響依賴快取。
# 這一步才把整個專案（包含 .go 檔案）複製進容器。
# 如果一開始就把所有檔案複製進去，Docker build cache 就會失效，導致每次都要重新跑 go mod download。
COPY . . 

# 在容器的 /app 目錄下，把 main.go 編譯成一個可執行檔，檔名叫 main。 (這個步驟會在映像建構時執行，產生可執行檔放在容器檔案系統裡)
RUN go build -o main main.go

EXPOSE 8080

# docker run 這個映像時，Docker 會執行 ./main，也就是剛剛編譯好的 Go 程式。
CMD ["./main"]